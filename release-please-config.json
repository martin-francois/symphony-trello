{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "maven",
  "pull-request-title-pattern": "chore${scope}: release${component} ${version} [skip ci]",
  "group-pull-request-title-pattern": "chore${scope}: release${component} ${version} [skip ci]",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "skip-snapshot": true,
  "draft": true,
  "force-tag-creation": true,
  "always-update": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "component": "symphony-trello",
      "package-name": "symphony-trello",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "install.sh"
        },
        {
          "type": "generic",
          "path": "install.ps1"
        }
      ]
    }
  }
}
