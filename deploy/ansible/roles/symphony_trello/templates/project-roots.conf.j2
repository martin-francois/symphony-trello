[Service]
# Managed by the Symphony for Trello Ansible role.
{% if symphony_trello_allow_host_filesystem %}
# Less secure: exposes the host filesystem to Codex sessions run by this service.
ProtectHome=false
ReadWritePaths=
ReadWritePaths=/
{% else %}
# Hide undeclared home-directory contents behind read-only empty filesystems, then bind only the
# declared roots back into the service namespace and make them writable despite ProtectSystem=strict.
ProtectHome=false
TemporaryFileSystem=
TemporaryFileSystem=/home:ro /root:ro /run/user:ro
BindPaths=
{% for project_root in symphony_trello_allowed_project_roots %}
BindPaths={{ project_root }}
{% endfor %}
ReadWritePaths=
ReadWritePaths={{ ([symphony_trello_state_dir] + symphony_trello_allowed_project_roots) | join(' ') }}
{% endif %}
