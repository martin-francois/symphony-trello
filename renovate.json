{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":rebaseStalePrs",
    "group:all"
  ],
  "reviewers": ["martinfrancois"],
  "labels": ["dependencies"],
  "rangeStrategy": "replace",
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "automerge": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^tessl\\.json$/"],
      "matchStrings": [
        "\"(?<depName>tessl-labs/good-oss-citizen)\"\\s*:\\s*\\{\\s*\"version\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "custom.tessl-tile",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci\\.yml$/",
        "/^\\.github/workflows/commitlint\\.yml$/"
      ],
      "matchStrings": ["corepack prepare pnpm@(?<currentValue>\\d+\\.\\d+\\.\\d+) --activate"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "pnpm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/commitlint\\.yml$/",
        "/^AGENTS\\.md$/",
        "/^CONTRIBUTING\\.md$/"
      ],
      "matchStrings": [
        "(?:--package\\s+|\\s+)(?<depName>@commitlint/(?:cli|config-conventional))@(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci\\.yml$/",
        "/^scripts/pwsh-docker\\.sh$/"
      ],
      "matchStrings": ["(?<depName>mcr\\.microsoft\\.com/dotnet/sdk):(?<currentValue>\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/semgrep-docker\\.sh$/"
      ],
      "matchStrings": ["(?<depName>semgrep/semgrep):(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "customDatasources": {
    "tessl-tile": {
      "defaultRegistryUrlTemplate": "https://api.tessl.io/v1/tiles/{{packageName}}",
      "transformTemplates": [
        "{\"releases\":[{\"version\": data.attributes.latestVersion, \"releaseTimestamp\": data.attributes.latestVersionData.attributes.createdAt}], \"homepage\":\"https://tessl.io/registry/\" & data.attributes.fullName}"
      ]
    }
  },
  "packageRules": [
    {
      "matchPackageNames": ["tessl-labs/good-oss-citizen"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["tessl"],
      "prBodyNotes": [
        "After Renovate updates `tessl.json`, run `tessl install`, review the refreshed `.tessl/tiles` diff, and commit those vendored tile changes before merging."
      ]
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["major-update"]
    }
  ]
}
