{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":rebaseStalePrs",
    "group:all"
  ],
  "reviewers": ["martinfrancois"],
  "labels": ["dependencies"],
  "rangeStrategy": "replace",
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "minimumReleaseAge": "3 days",
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "automerge": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^tessl\\.json$/"],
      "matchStrings": [
        "\"(?<depName>tessl-labs/good-oss-citizen)\"\\s*:\\s*\\{\\s*\"version\"\\s*:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "custom.tessl-tile",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci\\.yml$/",
        "/^\\.github/workflows/commitlint\\.yml$/"
      ],
      "matchStrings": ["corepack prepare pnpm@(?<currentValue>\\d+\\.\\d+\\.\\d+) --activate"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "pnpm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/commitlint\\.yml$/",
        "/^AGENTS\\.md$/",
        "/^CONTRIBUTING\\.md$/",
        "/^scripts/commitlint-local$/"
      ],
      "matchStrings": [
        "(?:--package\\s+|\\s+)(?<depName>@commitlint/(?:cli|config-conventional))@(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/ci\\.yml$/",
        "/^scripts/pwsh-docker\\.sh$/"
      ],
      "matchStrings": ["(?<depName>mcr\\.microsoft\\.com/dotnet/sdk):(?<currentValue>\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/semgrep-docker\\.sh$/"
      ],
      "matchStrings": ["docker\\.io/(?<depName>semgrep/semgrep):(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^scripts/betterleaks-docker\\.sh$/"
      ],
      "matchStrings": ["(?<depName>ghcr\\.io/betterleaks/betterleaks):v(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "customDatasources": {
    "tessl-tile": {
      "defaultRegistryUrlTemplate": "https://api.tessl.io/v1/tiles/{{packageName}}",
      "transformTemplates": [
        "{\"releases\":[{\"version\": data.attributes.latestVersion, \"releaseTimestamp\": data.attributes.latestVersionData.attributes.createdAt}], \"homepage\":\"https://tessl.io/registry/\" & data.attributes.fullName}"
      ]
    }
  },
  "packageRules": [
    {
      "matchDatasources": ["maven"],
      "matchPackageNames": [
        "com.google.errorprone:error_prone_core",
        "org.openrewrite:*",
        "org.openrewrite.maven:*",
        "org.openrewrite.recipe:*",
        "tech.picnic.error-prone-support:error-prone-contrib",
        "tech.picnic.error-prone-support:refaster-runner"
      ],
      "groupName": "OpenRewrite toolchain",
      "branchTopic": "openrewrite-toolchain",
      "minimumReleaseAge": "7 days",
      "rebaseWhen": "behind-base-branch",
      "automerge": true,
      "platformAutomerge": false,
      "dependencyDashboardApproval": false,
      "addLabels": ["openrewrite"],
      "prBodyNotes": [
        "Automation validates this dependency-only update and runs the ordered OpenRewrite and Spotless pipeline.",
        "When an eligible non-major update produces no repository change, required CI passes and Renovate automerges this pull request.",
        "When the toolchain changes source or POM output, this pull request remains blocked and automation opens or refreshes a separate generated pull request for maintainer review.",
        "Major updates retain dependency-dashboard approval and manual merge through the repository-wide major-update guard."
      ]
    },
    {
      "matchDatasources": ["maven"],
      "matchPackageNames": ["io.quarkus:quarkus-update-recipes"],
      "groupName": null,
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["quarkus"],
      "prBodyNotes": [
        "Quarkus updater recipe changes MUST NOT be validated as general OpenRewrite maintenance updates.",
        "Before merge, a maintainer MUST review the target Quarkus migration guide, run `quarkus:update` in the dependency-update branch, review the complete diff, and pass the full Maven gate."
      ]
    },
    {
      "matchPackageNames": ["tessl-labs/good-oss-citizen"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["tessl"],
      "prBodyNotes": [
        "After Renovate updates `tessl.json`, run `tessl install`, review the refreshed `.tessl/tiles` diff, and commit those vendored tile changes before merging."
      ]
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": ["major update"]
    }
  ]
}
